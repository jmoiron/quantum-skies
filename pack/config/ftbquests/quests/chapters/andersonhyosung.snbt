	quests: [
		{
			description: [
				"While there are normal ore veins on some of the rocky worlds in this solar system, probing deeper into their interiors can yield more valuable and more esoteric minerals."
				""
				"The &7Moon&r, despite being made out of a chunk of the &aEarth&r, is rich in minerals that are difficult to access back home. It probably helps that there's still &o&eland&r."
				""
				"&cMars&r and &eVenus&r have trace grains of the essence required to forge &anether stars&r."
			]
			icon: "minecraft:hopper_minecart"
