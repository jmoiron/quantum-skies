{
  "aquifers_enabled": false,
  "default_block": { "Name": "kubejs:titan_dirty_ice" },
  "default_fluid": { "Name": "gtceu:titan_hydrocarbon_mix" },
  "disable_mob_generation": true,
  "legacy_random_source": false,
  "noise": { "height": 384, "min_y": -64, "size_horizontal": 1, "size_vertical": 2 },
  "noise_router": {
    "barrier": { "type": "minecraft:noise", "noise": "minecraft:aquifer_barrier", "xz_scale": 1, "y_scale": 0.5 },
    "fluid_level_floodedness": { "type": "minecraft:shifted_noise", "shift_x": "minecraft:shift_x", "shift_y": 0, "shift_z": "minecraft:shift_z", "noise": "minecraft:aquifer_fluid_level_floodedness", "xz_scale": 1, "y_scale": 1 },
    "fluid_level_spread": { "type": "minecraft:noise", "noise": "minecraft:aquifer_fluid_level_spread", "xz_scale": 1, "y_scale": 0.714 },
    "lava": { "type": "minecraft:noise", "noise": "minecraft:aquifer_lava", "xz_scale": 0, "y_scale": 0 },
    "temperature": { "type": "minecraft:shifted_noise", "noise": "minecraft:temperature", "xz_scale": 0.25, "y_scale": 0.25, "shift_x": "minecraft:shift_x", "shift_y": 0, "shift_z": "minecraft:shift_z" },
    "vegetation": { "type": "minecraft:shifted_noise", "noise": "minecraft:vegetation", "xz_scale": 0.25, "y_scale": 0, "shift_x": 0, "shift_y": 0, "shift_z": 0 },
    "continents": { "type": "minecraft:noise", "noise": "minecraft:continentalness", "xz_scale": 1, "y_scale": 0 },
    "erosion": { "type": "minecraft:noise", "noise": "minecraft:erosion", "xz_scale": 1, "y_scale": 0 },
    "ridges": "minecraft:overworld/ridges",
    "depth": "minecraft:overworld/depth",
    "initial_density_without_jaggedness": "minecraft:overworld/base_3d_noise",
    "final_density": {
      "type": "minecraft:min",
      "argument1": {
        "type": "minecraft:squeeze",
        "argument": {
          "type": "minecraft:mul",
          "argument1": 0.64,
          "argument2": {
            "type": "minecraft:interpolated",
            "argument": { "type": "minecraft:blend_density", "argument": "minecraft:overworld/sloped_cheese" }
          }
        }
      },
      "argument2": "minecraft:overworld/caves/noodle"
    },
    "vein_toggle": { "type": "minecraft:noise", "noise": "minecraft:ore_veininess", "xz_scale": 1.5, "y_scale": 1.5 },
    "vein_ridged": { "type": "minecraft:noise", "noise": "minecraft:ore_vein_a", "xz_scale": 4, "y_scale": 4 },
    "vein_gap": { "type": "minecraft:noise", "noise": "minecraft:ore_gap", "xz_scale": 1, "y_scale": 1 }
  },
  "ore_veins_enabled": true,
  "sea_level": 44,
  "spawn_target": [
    {
      "temperature": [ -1, 0 ],
      "humidity": [ -1, 1 ],
      "continentalness": [ -1, 1 ],
      "erosion": [ -1, 1 ],
      "weirdness": [ -1, 1 ],
      "depth": 0,
      "offset": 0
    }
  ],
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      { "type": "minecraft:condition", "if_true": { "type": "minecraft:vertical_gradient", "random_name": "minecraft:bedrock_floor", "true_at_and_below": { "above_bottom": 0 }, "false_at_and_above": { "above_bottom": 5 } }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:bedrock" } } },

      { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": [ "gcyr:titan_dune_seas" ] },
        "then_run": { "type": "minecraft:sequence", "sequence": [
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": -1.0, "max_threshold": -0.35 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_hydrocarbon_sand" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": -0.35, "max_threshold": -0.1 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_hydrocarbon_sandstone" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:erosion", "min_threshold": 0.45, "max_threshold": 1.0 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:tholin_ice_dark" } } },
          { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_hydrocarbon_sand" } }
        ] } },

      { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": [ "gcyr:titan_lake_lowlands" ] },
        "then_run": { "type": "minecraft:sequence", "sequence": [
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:erosion", "min_threshold": -1.0, "max_threshold": -0.35 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:methane_clathrate" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": 0.35, "max_threshold": 1.0 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:tholin_ice_block" } } },
          { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_dirty_ice" } }
        ] } },

      { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": [ "gcyr:titan_interdune_plains" ] },
        "then_run": { "type": "minecraft:sequence", "sequence": [
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": -1.0, "max_threshold": -0.2 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_dirty_ice" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": -0.2, "max_threshold": 0.25 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:tholin_ice_light" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:erosion", "min_threshold": 0.4, "max_threshold": 1.0 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_hydrocarbon_sand" } } },
          { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_dirty_ice" } }
        ] } },

      { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": [ "gcyr:titan_rocky_uplands" ] },
        "then_run": { "type": "minecraft:sequence", "sequence": [
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": -1.0, "max_threshold": -0.15 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_cryorock" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:erosion", "min_threshold": -1.0, "max_threshold": -0.25 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_boulder_conglomerate" } } },
          { "type": "minecraft:condition", "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": 0.45, "max_threshold": 1.0 }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_dirty_ice" } } },
          { "type": "minecraft:block", "result_state": { "Name": "kubejs:titan_cryorock" } }
        ] } }
    ]
  }
}
